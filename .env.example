# Engram Configuration
# Copy this to .env and customize

# Server
ENGRAM_PORT=4200
ENGRAM_HOST=0.0.0.0

# GUI password (required — change this!)
ENGRAM_GUI_PASSWORD=changeme

# Optional: LLM for automatic fact extraction
# Supports any OpenAI-compatible API
# LLM_URL=http://localhost:4100/v1/chat/completions
# LLM_API_KEY=your-api-key
# LLM_MODEL=claude-sonnet-4-20250514

# Embedding model (default: all-MiniLM-L6-v2, 384 dimensions)
# Only change if you know what you're doing
# EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
