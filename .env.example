# Engram Configuration
# Copy this to .env and customize

# ============================================================================
# Server
# ============================================================================
ENGRAM_PORT=4200
ENGRAM_HOST=0.0.0.0

# ============================================================================
# Security
# ============================================================================

# GUI password (required — change this!)
ENGRAM_GUI_PASSWORD=changeme

# Open access mode: unauthenticated requests get full admin.
# ONLY enable behind a trusted network (VPN, firewall, localhost).
# Default: disabled (API key required for all endpoints except /health)
# ENGRAM_OPEN_ACCESS=1

# IP allowlist (comma-separated). Empty = allow all.
# ENGRAM_ALLOWED_IPS=127.0.0.1,10.0.0.0/8

# CORS origin. Default: * (allow all origins)
# ENGRAM_CORS_ORIGIN=https://your-app.example.com

# Max request body size in bytes (default: 1MB)
# ENGRAM_MAX_BODY_SIZE=1048576

# Max memory content size in bytes (default: 100KB)
# ENGRAM_MAX_CONTENT_SIZE=102400

# ============================================================================
# LLM (optional — enables fact extraction, auto-tagging, consolidation)
# Supports any OpenAI-compatible API
# ============================================================================
# LLM_URL=http://localhost:4100/v1/chat/completions
# LLM_API_KEY=your-api-key
# LLM_MODEL=claude-sonnet-4-20250514

# ============================================================================
# Advanced
# ============================================================================

# Embedding model (default: all-MiniLM-L6-v2, 384 dimensions)
# Only change if you know what you're doing — changing this invalidates all existing embeddings
# EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Log level: debug, info, warn, error, none (default: info)
# ENGRAM_LOG_LEVEL=info
