[Unit]
Description=Engram v5.1 persistent memory server
After=network.target copilot-proxy.service

[Service]
Type=simple
WorkingDirectory=/home/zan/zanmemory-opencode
ExecStart=/home/zan/.bun/bin/bun run server.ts
Restart=on-failure
RestartSec=5
Environment=ZANMEMORY_PORT=4200
Environment=ZANMEMORY_HOST=0.0.0.0

[Install]
WantedBy=default.target
